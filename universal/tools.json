[
  {
    "type": "function",
    "function": {
      "name": "tronclass_get_courses",
      "description": "获取用户的所有课程列表",
      "parameters": { "type": "object", "properties": {}, "required": [] }
    },
    "execute": "agent-browser --session-name cuc eval \"fetch('/api/user/recently-visited-courses').then(r=>r.json()).then(d=>JSON.stringify(d.visited_courses.map(c=>({id:c.id,name:c.name,dept:c.department?.name}))))\""
  },
  {
    "type": "function",
    "function": {
      "name": "tronclass_get_todos",
      "description": "获取待办作业列表（含截止时间）",
      "parameters": { "type": "object", "properties": {}, "required": [] }
    },
    "execute": "agent-browser --session-name cuc eval \"fetch('/api/todos?no-intercept=true').then(r=>r.json()).then(d=>JSON.stringify(d.todo_list.map(t=>({title:t.title,course:t.course_name,due:t.end_time,id:t.id,course_id:t.course_id}))))\""
  },
  {
    "type": "function",
    "function": {
      "name": "tronclass_get_homework_detail",
      "description": "获取指定作业的详情（标题、截止时间、要求）",
      "parameters": {
        "type": "object",
        "properties": {
          "activity_id": { "type": "integer", "description": "作业的 activity ID" }
        },
        "required": ["activity_id"]
      }
    },
    "execute": "agent-browser --session-name cuc eval \"fetch('/api/activities/${activity_id}?sub_course_id=0').then(r=>r.json()).then(d=>JSON.stringify({title:d.title,end:d.end_time,desc:d.data?.description,closed:d.is_closed}))\""
  },
  {
    "type": "function",
    "function": {
      "name": "tronclass_get_coursewares",
      "description": "获取指定课程的课件/资料列表",
      "parameters": {
        "type": "object",
        "properties": {
          "course_id": { "type": "integer", "description": "课程 ID" }
        },
        "required": ["course_id"]
      }
    },
    "execute": "agent-browser --session-name cuc eval \"fetch('/api/course/${course_id}/coursewares?conditions={\\\"category\\\":null,\\\"itemsSortBy\\\":{\\\"predicate\\\":\\\"chapter\\\",\\\"reverse\\\":false}}').then(r=>r.json()).then(d=>JSON.stringify(d.activities.map(a=>({id:a.id,title:a.title}))))\""
  },
  {
    "type": "function",
    "function": {
      "name": "tronclass_get_file_references",
      "description": "获取指定活动的附件文件列表",
      "parameters": {
        "type": "object",
        "properties": {
          "activity_id": { "type": "integer", "description": "活动 ID" }
        },
        "required": ["activity_id"]
      }
    },
    "execute": "agent-browser --session-name cuc eval \"fetch('/api/activities/${activity_id}/upload_references').then(r=>r.json()).then(d=>JSON.stringify(d.references.map(r=>({name:r.name,upload_id:r.upload.id,size:r.upload.size}))))\""
  },
  {
    "type": "function",
    "function": {
      "name": "tronclass_get_download_url",
      "description": "获取文件的签名下载URL（可直接用curl下载，不需要认证）",
      "parameters": {
        "type": "object",
        "properties": {
          "upload_id": { "type": "integer", "description": "文件的 upload ID" }
        },
        "required": ["upload_id"]
      }
    },
    "execute": "agent-browser --session-name cuc eval \"fetch('/api/uploads/${upload_id}/url').then(r=>r.json()).then(d=>d.url)\""
  },
  {
    "type": "function",
    "function": {
      "name": "tronclass_get_grades",
      "description": "获取指定课程的成绩",
      "parameters": {
        "type": "object",
        "properties": {
          "course_id": { "type": "integer", "description": "课程 ID" }
        },
        "required": ["course_id"]
      }
    },
    "execute": "agent-browser --session-name cuc eval \"fetch('/api/courses/${course_id}/exam-scores').then(r=>r.json()).then(d=>JSON.stringify(d))\""
  },
  {
    "type": "function",
    "function": {
      "name": "tronclass_get_rollcalls",
      "description": "获取指定课程的签到记录",
      "parameters": {
        "type": "object",
        "properties": {
          "course_id": { "type": "integer", "description": "课程 ID" }
        },
        "required": ["course_id"]
      }
    },
    "execute": "agent-browser --session-name cuc eval \"fetch('/api/courses/${course_id}/modules/rollcalls').then(r=>r.json()).then(d=>JSON.stringify(d.rollcalls.map(r=>({title:r.title,time:r.rollcall_time,status:r.status}))))\""
  },
  {
    "type": "function",
    "function": {
      "name": "tronclass_get_discussions",
      "description": "获取指定讨论活动的帖子列表",
      "parameters": {
        "type": "object",
        "properties": {
          "activity_id": { "type": "integer", "description": "讨论活动 ID" }
        },
        "required": ["activity_id"]
      }
    },
    "execute": "agent-browser --session-name cuc eval \"fetch('/api/activities/${activity_id}/comments?page=1&page_size=20&order_key=id&order=desc&conditions={\\\"referrer_type\\\":\\\"none\\\",\\\"type\\\":\\\"comment\\\"}').then(r=>r.json()).then(d=>JSON.stringify({total:d.total,posts:(d.comments||[]).map(c=>({user:c.user?.name,text:c.content?.substring(0,200)}))}))\""
  },
  {
    "type": "function",
    "function": {
      "name": "tronclass_check_session",
      "description": "检查 TronClass 登录态是否有效",
      "parameters": { "type": "object", "properties": {}, "required": [] }
    },
    "execute": "agent-browser --session-name cuc eval \"fetch('/api/todos?no-intercept=true').then(r=>r.ok?'valid':'expired')\""
  }
]
